# QualiGuard production ortam değişkenleri
# Kopyala: cp .env.example .env

# Sunucu
QG_HOST=0.0.0.0
QG_PORT=9000
QG_DATA_DIR=./data

# Panel girişi (internet'e açarken opsiyonel admin şifresi)
# QG_PANEL_PASSWORD=guclu-sifreniz

# Public website mode (docker-compose.prod.yml içinde 1)
# 1 = sadece pazarlama + hesap + indirme; panel/analiz kapalı
# Masaüstü uygulamasında bu değişkeni set etme
# QG_PUBLIC_SITE=1

# HTTPS (Caddy ile deploy)
QG_DOMAIN=qualiguard.example.com
QG_EMAIL=admin@example.com

# Yapay zeka (opsiyonel — Ollama ayrı servis)
# QUALIGUARD_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
